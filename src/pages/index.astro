---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base.replace(/\/?$/, '/')}${path.replace(/^\//, '')}`;

const links = [
  { label: 'Personal Page', sublabel: 'Profile, works, skills', href: asset('/profile/'), external: false },
  { label: 'GitHub', sublabel: '@shobioinfo', href: 'https://github.com/shobioinfo', external: true },
  {
    label: 'Scholar',
    sublabel: 'Publications',
    href: 'https://scholar.google.co.jp/citations?view_op=list_works&hl=ja&hl=ja&user=QwiO-48AAAAJ',
    external: true,
  },
  {
    label: 'LinkedIn',
    sublabel: 'Career profile',
    href: 'https://jp.linkedin.com/in/sho-oshima-508316309',
    external: true,
  },
  { label: 'Qiita', sublabel: 'Notes and articles', href: 'https://qiita.com/shobioinfo', external: true },
];
---

<Base>
  <main class="landing">
    <section class="hero hero-home">
      <div class="hero-copy">
        <p class="eyebrow reveal">Computational Biology / Graph Representation Learning / Probabilistic Models</p>
        <h1 class="hero-name reveal">Sho Oshima</h1>
        <p class="hero-role reveal">Machine Learning Researcher / M.S., Graduate School of Medicine, Kyoto University / Based in Japan</p>
        <p class="hero-summary reveal">
          Developing machine learning theory and methods tailored to biological systems, with a focus on biologically
          grounded representation learning, graph machine learning, and generative modeling for biomedical data.
        </p>
        <nav class="hero-links reveal" aria-label="Primary links">
          {links.map((link) => <a class="link" href={link.href} rel="me noopener" target="_blank">{link.label}</a>)}
          <button
            class="link"
            id="email"
            type="button"
            data-user="oshima.sho.kyoto"
            data-domain="gmail.com"
            aria-label="Reveal email"
          >
            Email
          </button>
        </nav>
        <div class="portal-grid reveal" aria-label="Navigation links">
          {
            links.map((link) => (
              <a class="portal-card" href={link.href} rel={link.external ? 'me noopener' : undefined} target={link.external ? '_blank' : undefined}>
                <span>{link.label}</span>
                <small>{link.sublabel}</small>
              </a>
            ))
          }
        </div>
      </div>
      <figure class="hero-portrait reveal">
        <img src={asset('/img/IMG_7956.JPG')} alt="Portrait of Sho Oshima" />
      </figure>
    </section>
  </main>
</Base>
